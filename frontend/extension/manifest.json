{
  "manifest_version": 3,
  "name": "SalesWhisper",
  "version": "1.0.0",
  "description": "AI-powered real-time sales coach",
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://*.zoom.us/*",
    "https://meet.google.com/*",
    "https://*.teams.microsoft.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.zoom.us/*",
        "https://meet.google.com/*",
        "https://*.teams.microsoft.com/*"
      ],
      "js": ["src/content.js"]
    }
  ],
  "background": {
    "service_worker": "src/background.js"
  }
}